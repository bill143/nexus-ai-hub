# ============================================================
# NEXUS AI Hub — Environment Variables
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public anon key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER SIDE ONLY, never expose to browser
# Used only in createAdminClient() for audit log writes and invite acceptance
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── APP ──────────────────────────────────────────────────────
# Your deployment URL (no trailing slash)
# Local: http://localhost:3000
# Production: https://nexus-ai-hub.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OPTIONAL: EMAIL (Phase 2) ────────────────────────────────
# Resend API key for transactional email (invite emails, etc.)
# Sign up at https://resend.com — free tier: 3,000 emails/month
# RESEND_API_KEY=re_your_key_here
# RESEND_FROM_EMAIL=noreply@yourcompany.com

# ── OPTIONAL: ANALYTICS (Phase 2) ───────────────────────────
# PostHog for product analytics
# Sign up at https://posthog.com — free tier: 1M events/month
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── OPTIONAL: BILLING (Phase 3) ─────────────────────────────
# Stripe for subscription management
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# STRIPE_SECRET_KEY=sk_test_your_key
# STRIPE_WEBHOOK_SECRET=whsec_your_secret
